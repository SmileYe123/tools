/* ============================================
   MultiTool 专业UI设计系统 - 深色主题
   基于现代设计原则：一致性、层次感、可用性
   ============================================ */

/* === 全局样式 === */
* {
    font-family: 'PingFang SC', 'Microsoft YaHei', 'Segoe UI', -apple-system, sans-serif;
    outline: none;
    selection-background-color: #1E40AF;
}

/* === 主窗口 === */
QMainWindow {
    background: #0F172A;
}

QMainWindow > QWidget {
    background: transparent;
}

/* === 侧边栏设计 === */
QWidget#sidebar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1F2937, stop:0.5 #111827, stop:1 #0F172A);
    border-right: 1px solid #374151;
}

QWidget#sidebar_header {
    background: transparent;
    border-bottom: 1px solid #374151;
}

QLabel#sidebar_title {
    color: #F9FAFB;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.5px;
    padding: 0;
}

/* 搜索框 */
QLineEdit#sidebar_search {
    background-color: #1F2937;
    border: 1px solid #374151;
    border-radius: 10px;
    padding: 10px 14px;
    color: #E5E7EB;
    font-size: 13px;
}

QLineEdit#sidebar_search:hover {
    background-color: #111827;
    border-color: #4B5563;
}

QLineEdit#sidebar_search:focus {
    border: 2px solid #3B82F6;
    background-color: #111827;
    padding: 9px 13px;
}

QFrame#sidebar_line {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 transparent, stop:0.5 #374151, stop:1 transparent);
    max-height: 1px;
}

QScrollArea#sidebar_scroll {
    background-color: transparent;
    border: none;
}

QWidget#sidebar_scroll_widget {
    background-color: transparent;
}

/* 分类标签 */
QLabel#category_label {
    color: #6B7280;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 12px 16px 4px 16px;
}

/* === 工具按钮（侧边栏菜单项）=== */
QToolButton {
    background-color: transparent;
    color: #9CA3AF;
    border: none;
    border-radius: 10px;
    padding: 10px 14px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    min-height: 44px;
    margin: 2px 8px;
}

QToolButton:hover {
    background-color: #1F2937;
    color: #F9FAFB;
}

QToolButton:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #1E3A8A, stop:1 #1E40AF);
    color: #60A5FA;
    font-weight: 600;
    border-left: 3px solid #3B82F6;
    margin-left: 5px;
    padding-left: 11px;
}

QToolButton:pressed {
    background-color: #1E40AF;
    color: #93C5FD;
}

/* === 按钮系统 === */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #3B82F6, stop:1 #2563EB);
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    padding: 12px 28px;
    font-weight: 600;
    font-size: 14px;
    min-height: 44px;
    letter-spacing: 0.3px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #60A5FA, stop:1 #3B82F6);
    color: #FFFFFF;
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #2563EB, stop:1 #1D4ED8);
}

QPushButton:disabled {
    background: #374151;
    color: #6B7280;
}

QPushButton[secondary="true"] {
    background: #1F2937;
    color: #E5E7EB;
    border: 1px solid #4B5563;
}

QPushButton[secondary="true"]:hover {
    background: #374151;
    border-color: #6B7280;
    color: #F9FAFB;
}

QPushButton[secondary="true"]:pressed {
    background: #4B5563;
    border-color: #9CA3AF;
}

/* === 分组框 === */
QGroupBox {
    background-color: #1F2937;
    border: 1px solid #374151;
    border-radius: 12px;
    margin-top: 24px;
    padding: 20px;
    padding-top: 28px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 16px;
    padding: 0 8px;
    color: #E5E7EB;
    font-weight: 600;
    font-size: 14px;
    background-color: #1F2937;
}

/* === 输入框 === */
QLineEdit {
    background-color: #1F2937;
    border: 1px solid #374151;
    border-radius: 8px;
    padding: 10px 14px;
    color: #E5E7EB;
    font-size: 14px;
    selection-background-color: #1E40AF;
}

QLineEdit:hover {
    background-color: #111827;
    border-color: #4B5563;
}

QLineEdit:focus {
    border: 2px solid #3B82F6;
    background-color: #111827;
    padding: 9px 13px;
}

QLineEdit:read-only {
    background-color: #111827;
    color: #6B7280;
}

/* === 文本编辑区 === */
QTextEdit {
    background-color: #111827;
    border: 1px solid #374151;
    border-radius: 10px;
    padding: 14px;
    color: #E5E7EB;
    font-size: 14px;
    font-family: 'Consolas', 'Courier New', monospace;
    selection-background-color: #1E40AF;
}

QTextEdit:hover {
    border-color: #4B5563;
}

QTextEdit:focus {
    border: 2px solid #3B82F6;
    padding: 13px;
}

/* === 下拉框 === */
QComboBox {
    background-color: #1F2937;
    border: 1px solid #374151;
    border-radius: 8px;
    padding: 10px 14px;
    color: #E5E7EB;
    font-size: 14px;
    min-height: 20px;
}

QComboBox:hover {
    background-color: #111827;
    border-color: #4B5563;
}

QComboBox:focus {
    border: 2px solid #3B82F6;
    padding: 9px 13px;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
    padding-right: 8px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #9CA3AF;
    margin-right: 4px;
}

QComboBox QAbstractItemView {
    background-color: #1F2937;
    border: 1px solid #374151;
    border-radius: 8px;
    selection-background-color: #1E40AF;
    selection-color: #93C5FD;
    color: #E5E7EB;
    padding: 6px;
    font-size: 14px;
}

/* === 数字输入框 === */
QSpinBox {
    background-color: #1F2937;
    border: 1px solid #374151;
    border-radius: 8px;
    padding: 10px;
    color: #E5E7EB;
    font-size: 14px;
    min-height: 20px;
}

QSpinBox:hover {
    background-color: #111827;
    border-color: #4B5563;
}

QSpinBox:focus {
    border: 2px solid #3B82F6;
    padding: 9px;
}

QSpinBox::up-button, QSpinBox::down-button {
    background-color: transparent;
    border: none;
    width: 18px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background-color: #374151;
}

/* === 滑块 === */
QSlider::groove:horizontal {
    background: #374151;
    height: 6px;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #3B82F6;
    width: 18px;
    margin: -6px 0;
    border-radius: 9px;
}

QSlider::handle:horizontal:hover {
    background: #60A5FA;
    width: 20px;
    margin: -7px 0;
}

QSlider::sub-page:horizontal {
    background: #3B82F6;
    border-radius: 3px;
}

/* === 标签 === */
QLabel {
    color: #E5E7EB;
    background-color: transparent;
    font-size: 14px;
}

QLabel[isHeader="true"] {
    color: #F9FAFB;
    font-size: 16px;
    font-weight: 600;
}

/* === 表格 === */
QTableWidget {
    background-color: #0F172A;
    alternate-background-color: #1E293B;
    border: 1px solid #334155;
    border-radius: 12px;
    gridline-color: #334155;
    selection-background-color: #1E3A8A;
    selection-color: #93C5FD;
    padding: 4px;
}

QHeaderView::section {
    background-color: #1E293B;
    color: #94A3B8;
    padding: 14px 16px;
    border: none;
    border-bottom: 2px solid #334155;
    font-weight: 600;
    font-size: 13px;
}

QHeaderView::section:hover {
    background-color: #334155;
    color: #F1F5F9;
}

QTableWidget QTableCornerButton::section {
    background-color: #1E293B;
    border: none;
    border-bottom: 2px solid #334155;
}

/* === 滚动条 === */
QScrollBar:vertical {
    background-color: transparent;
    width: 12px;
    margin: 4px;
}

QScrollBar::handle:vertical {
    background-color: rgba(75, 85, 99, 180);
    border-radius: 6px;
    min-height: 40px;
}

QScrollBar::handle:vertical:hover {
    background-color: rgba(107, 114, 128, 200);
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: transparent;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 12px;
    margin: 4px;
}

QScrollBar::handle:horizontal {
    background-color: rgba(75, 85, 99, 180);
    border-radius: 6px;
    min-width: 40px;
}

QScrollBar::handle:horizontal:hover {
    background-color: rgba(107, 114, 128, 200);
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

/* === 状态栏 === */
QStatusBar {
    background: #111827;
    border-top: 1px solid #374151;
    color: #6B7280;
    font-size: 12px;
    padding: 6px 12px;
}

QStatusBar QLabel {
    color: #6B7280;
    font-size: 12px;
}

/* === 欢迎页 === */
QWidget#welcome_page {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #0F172A, stop:0.5 #1E293B, stop:1 #0F172A);
}

QLabel#welcome_title {
    color: #F1F5F9;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.5px;
}

QLabel#welcome_subtitle {
    color: #94A3B8;
    font-size: 16px;
    font-weight: 400;
}

/* === 快捷卡片 === */
QWidget#quick_card {
    background-color: #1E293B;
    border: 1px solid #334155;
    border-radius: 16px;
}

QWidget#quick_card:hover {
    background-color: #334155;
    border: 1px solid #475569;
}

QLabel#card_title {
    color: #F1F5F9;
    font-size: 16px;
    font-weight: 600;
}

QLabel#card_desc {
    color: #94A3B8;
    font-size: 14px;
}

/* === 菜单 === */
QMenu {
    background-color: #1F2937;
    border: 1px solid #374151;
    border-radius: 12px;
    padding: 8px;
}

QMenu::item {
    padding: 8px 32px 8px 12px;
    border-radius: 6px;
    color: #E5E7EB;
    font-size: 14px;
    font-weight: 400;
}

QMenu::item:selected {
    background-color: #1E40AF;
    color: #93C5FD;
}

QMenu::separator {
    height: 1px;
    background-color: #374151;
    margin: 6px 8px;
}

/* === 工具提示 === */
QToolTip {
    background-color: #374151;
    border: none;
    border-radius: 8px;
    padding: 8px 12px;
    color: #F9FAFB;
    font-size: 13px;
    font-weight: 400;
}

/* === 复选框 === */
QCheckBox {
    color: #9CA3AF;
    font-size: 14px;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1px solid #4B5563;
    background-color: #1F2937;
}

QCheckBox::indicator:hover {
    border-color: #3B82F6;
}

QCheckBox::indicator:checked {
    background-color: #3B82F6;
    border-color: #3B82F6;
}

QCheckBox::indicator:pressed {
    background-color: #1E40AF;
}

/* === 进度条 === */
QProgressBar {
    background-color: #374151;
    border: none;
    border-radius: 6px;
    height: 8px;
    text-align: center;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #3B82F6, stop:1 #60A5FA);
    border-radius: 6px;
}
